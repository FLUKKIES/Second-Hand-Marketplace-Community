generator client {
    provider        = "prisma-client-js"
    // เปิดใช้งานฟีเจอร์จัดการ Extension ของ Postgres
    previewFeatures = ["postgresqlExtensions"]
}

datasource db {
    provider   = "postgresql"
    // เปิดใช้งาน pgvector extension
    extensions = [vector]
}

// ==========================================
// 1. Enums (Standardized Statuses)
// ==========================================

enum Role {
    USER
    ADMIN
}

enum AuthProvider {
    LOCAL
    GOOGLE
}

enum GroupRole {
    MEMBER
    ADMIN
}

enum PostType {
    NORMAL
    SELLING
}

enum OfferStatus {
    PENDING
    ACCEPTED
    REJECTED
    COUNTER_OFFERED
    EXPIRED
    CANCELLED
}

enum OrderStatus {
    TO_PAY
    TO_SHIP
    TO_RECEIVE
    COMPLETED
    CANCELLED
}

// ==========================================
// 2. User & Identity
// ==========================================

model User {
    id       String  @id @default(uuid())
    username String  @unique
    email    String  @unique
    password String?

    firstName String?
    lastName  String?

    provider   AuthProvider @default(LOCAL)
    providerId String?

    avatarUrl String?
    bio       String?
    role      Role    @default(USER)

    // Ban & Moderation
    isBanned     Boolean   @default(false)
    bannedAt     DateTime?
    banExpiresAt DateTime? // If null but isBanned=true, it's permanent
    banReason    String?
    warningCount Int       @default(0)

    phoneNumber String?

    acceptedTermsAt DateTime?

    // Relations to separated tables
    addresses    Address[]
    bankAccounts BankAccount[]

    groupMemberships GroupMember[]
    posts            Post[]

    offersMade    Offer[]
    ordersBuying  Order[] @relation("BuyerOrders")
    ordersSelling Order[] @relation("SellerOrders")

    reviewsWritten  Review[] @relation("WrittenReviews")
    reviewsReceived Review[] @relation("ReceivedReviews")

    comments Comment[]
    likes    Like[]

    chatInitiated ChatRoom[]    @relation("ChatInitiator")
    chatReceived  ChatRoom[]    @relation("ChatRecipient")
    messages      ChatMessage[]

    createdAt     DateTime       @default(now())
    updatedAt     DateTime       @updatedAt
    notifications Notification[]
    // messageReactions MessageReaction[]
    reportsMade   Report[]       @relation("Reporter")
    reports       Report[]

    followedBy Follow[] @relation("followedBy")
    following  Follow[] @relation("following")

    @@map("users")
}

model Address {
    id String @id @default(uuid())

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    label        String  @default("Home") // Home, Office, etc.
    addressLine1 String
    addressLine2 String?
    subDistrict  String // Tambon
    district     String // Amphoe
    province     String // Changwat
    postalCode   String
    phoneNumber  String? // Contact for this address

    isDefault Boolean @default(false)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("addresses")
}

model Bank {
    id           String  @id @default(uuid()) // Or use standard codes like '002' for BBL
    name         String // Kasikorn Bank
    code         String  @unique // kbank, scb, etc.
    officialName String // ธนาคารกสิกรไทย
    logoUrl      String?

    accounts BankAccount[]

    @@map("banks")
}

model BankAccount {
    id String @id @default(uuid())

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    bankId String
    bank   Bank   @relation(fields: [bankId], references: [id])

    accountNumber String
    accountName   String
    isDefault     Boolean @default(false)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("bank_accounts")
}

// ==========================================
// 3. Community Structure
// ==========================================

model Category {
    id       Int     @id @default(autoincrement())
    name     String  @unique
    slug     String  @unique
    imageUrl String?

    groups Group[]

    createdAt DateTime @default(now())

    @@map("categories")
}

model Group {
    id            String  @id @default(uuid())
    name          String
    description   String? @db.Text
    imageUrl      String?
    backgroundUrl String?

    categoryId Int
    category   Category @relation(fields: [categoryId], references: [id])

    members GroupMember[]
    posts   Post[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("groups")
}

model GroupMember {
    id     String @id @default(uuid())
    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    groupId String
    group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

    role     GroupRole @default(MEMBER)
    joinedAt DateTime  @default(now())

    @@unique([userId, groupId])
    @@map("group_members")
}

// ==========================================
// 4. Content (Post & Product Separation) + VECTOR SUPPORT
// ==========================================

model Post {
    id           String   @id @default(uuid())
    content      String?  @db.Text
    type         PostType @default(NORMAL)
    shippingCost Decimal  @default(0) @db.Decimal(10, 2)

    authorId String
    author   User   @relation(fields: [authorId], references: [id])

    groupId String
    group   Group  @relation(fields: [groupId], references: [id])

    images   PostImage[]
    comments Comment[]
    likes    Like[]

    products Product[]

    // *** Vector Embedding Field ***
    // ใช้ Unsupported เพราะ Prisma ยังไม่มี Native type สำหรับ vector
    // ขนาด 1024 สำหรับ bge-m3
    embedding Unsupported("vector(1024)")?

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    // Index เพื่อการค้นหาที่รวดเร็ว (HNSW คือ Algorithm ที่นิยมใช้กับ Vector Search)
    // @@index([embedding], name: "post_embedding_index", type: hnsw)
    @@map("posts")
}

model PostImage {
    id     String @id @default(uuid())
    url    String
    postId String
    post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

    @@map("post_images")
}

model Product {
    id     String @id @default(uuid())
    postId String
    post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

    name        String
    price       Decimal @db.Decimal(10, 2)
    description String?
    stock       Int     @default(1)
    isSoldOut   Boolean @default(false)
    imageUrl    String? // 1 Product has 1 Image

    // *** Vector Embedding Field ***
    // แยก Embedding ของ Product ออกมาต่างหาก เพื่อให้ค้นหาสินค้าได้แม่นยำขึ้น
    embedding Unsupported("vector(1024)")?

    offers     Offer[]
    orderItems OrderItem[]

    // Index สำหรับค้นหาสินค้า
    // @@index([embedding], name: "product_embedding_index", type: hnsw)
    @@map("products")
}

// ==========================================
// 5. Negotiation (Offer System)
// ==========================================

model Offer {
    id String @id @default(uuid())

    buyerId String
    buyer   User   @relation(fields: [buyerId], references: [id])

    productId String
    product   Product @relation(fields: [productId], references: [id])

    offeredPrice Decimal @db.Decimal(10, 2)

    buyerNote  String? @db.Text
    sellerNote String? @db.Text

    // Counter-offer fields
    counterPrice Decimal? @db.Decimal(10, 2)
    counterNote  String?  @db.Text
    counterCount Int      @default(0)

    // Expiration
    expiresAt DateTime?

    status OfferStatus @default(PENDING)

    orderId String?
    order   Order?  @relation(fields: [orderId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("offers")
}

// ==========================================
// 6. Order & Transaction
// ==========================================

model Order {
    id String @id @default(uuid())

    buyerId String
    buyer   User   @relation("BuyerOrders", fields: [buyerId], references: [id])

    sellerId String
    seller   User   @relation("SellerOrders", fields: [sellerId], references: [id])

    totalPrice Decimal     @db.Decimal(10, 2)
    status     OrderStatus @default(TO_PAY)

    shippingAddress String @db.Text
    paymentSnapshot Json

    paymentSlipUrl String?
    trackingNumber String?

    paymentDueAt DateTime? // Expiration time for payment

    items  OrderItem[]
    offers Offer[]
    review Review?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("orders")
}

model OrderItem {
    id String @id @default(uuid())

    orderId String
    order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

    productId String
    product   Product @relation(fields: [productId], references: [id])

    quantity Int     @default(1)
    price    Decimal @db.Decimal(10, 2)

    @@map("order_items")
}

// ==========================================
// 7. Social
// ==========================================

model Review {
    id      String  @id @default(uuid())
    rating  Int
    comment String? @db.Text

    orderId String @unique
    order   Order  @relation(fields: [orderId], references: [id])

    reviewerId String
    reviewer   User   @relation("WrittenReviews", fields: [reviewerId], references: [id])

    targetId String
    target   User   @relation("ReceivedReviews", fields: [targetId], references: [id])

    createdAt DateTime @default(now())

    @@map("reviews")
}

model Comment {
    id      String @id @default(uuid())
    content String @db.Text

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    postId String
    post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("comments")
}

model Like {
    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    postId String
    post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())

    @@id([userId, postId])
    @@map("likes")
}

// ==========================================
// 8. Chat System
// ==========================================

model ChatRoom {
    id String @id @default(uuid())

    initiatorId String
    initiator   User   @relation("ChatInitiator", fields: [initiatorId], references: [id])

    recipientId String
    recipient   User   @relation("ChatRecipient", fields: [recipientId], references: [id])

    messages ChatMessage[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Prevent duplicate rooms
    @@unique([initiatorId, recipientId])
    @@index([initiatorId])
    @@index([recipientId])
    @@map("chat_rooms")
}

enum MessageType {
    TEXT
    IMAGE
    OFFER_SENT
    SYSTEM
}

model ChatMessage {
    id       String      @id @default(uuid())
    content  String?     @db.Text
    type     MessageType @default(TEXT)
    metadata Json?

    roomId String
    room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

    senderId String
    sender   User   @relation(fields: [senderId], references: [id])

    isRead Boolean   @default(false)
    readAt DateTime?

    createdAt DateTime @default(now())
    // messageReactions MessageReaction[]

    @@map("chat_messages")
}

// ==========================================
// 8. Notifications
// ==========================================

model Notification {
    id     String @id @default(uuid())
    userId String // ผู้รับแจ้งเตือน
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    type    NotificationType
    title   String
    message String
    data    Json? // เก็บข้อมูลเพิ่มเติม เช่น { orderId: "...", offerId: "..." }
    isRead  Boolean          @default(false)

    createdAt DateTime @default(now())

    @@index([userId])
    @@map("notifications")
}

enum NotificationType {
    OFFER_RECEIVED // มีคนมาต่อราคา
    OFFER_ACCEPTED // คำขอต่อราคาได้รับการอนุมัติ
    OFFER_REJECTED // คำขอต่อราคาถูกปฏิเสธ
    OFFER_COUNTERED // ผู้ขายเสนอราคาใหม่

    ORDER_CREATED // มีคำสั่งซื้อเข้ามา (สำหรับคนขาย)
    ORDER_PAID // ลูกค้าแจ้งโอนเงิน (สำหรับคนขาย)
    ORDER_SHIPPED // ร้านค้าส่งของแล้ว (สำหรับคนซื้อ)
    ORDER_COMPLETED // ลูกค้ารับของแล้ว (สำหรับคนขาย)
    ORDER_CANCELLED // ยกเลิกออเดอร์

    SYSTEM // แจ้งเตือนจากระบบ
    REPORT_STATUS_UPDATED // แจ้งเตือนเมื่อสถานะการรายงานเปลี่ยน
    WARNING_RECEIVED // แจ้งเตือนเมื่อได้รับคำเตือนจาก Admin
}

// ==========================================
// 9. Report & Moderation
// ==========================================

enum TargetType {
    USER
    POST
    GROUP
}

enum ReportStatus {
    PENDING
    RESOLVED
    DISMISSED
}

model Report {
    id String @id @default(uuid())

    reporterId String
    reporter   User   @relation("Reporter", fields: [reporterId], references: [id])

    targetType TargetType
    targetId   String // ID of User, Post, or Group being reported

    reason String       @db.Text
    status ReportStatus @default(PENDING)

    adminNotes String? @db.Text // Admin's internal notes

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    user      User?    @relation(fields: [userId], references: [id])
    userId    String?

    @@map("reports")
}

// ==========================================
// 10. Social Graph (Follow System)
// ==========================================

model Follow {
    followerId String
    follower   User   @relation("following", fields: [followerId], references: [id], onDelete: Cascade)

    followingId String
    following   User   @relation("followedBy", fields: [followingId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())

    @@id([followerId, followingId])
    @@map("follows")
}
