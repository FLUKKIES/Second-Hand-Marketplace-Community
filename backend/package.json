        "express": "^5.2.1",
        "fs": "0.0.1-security",
        "multer": "^2.0.2",
        "passport": "^0.7.0",
        "passport-google-oauth20": "^2.0.0",
        "passport-jwt": "^4.0.1",
        "pg": "^8.16.3",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "slugify": "^1.6.6",
        "socket.io": "^4.8.1",
        "swagger-ui-express": "^5.0.1",
        "uuid": "^13.0.0"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.2.0",
        "@eslint/js": "^9.18.0",
        "@nestjs/cli": "^11.0.0",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.1",
        "@types/express": "^5.0.0",
        "@types/jest": "^30.0.0",
        "@types/multer": "^2.0.0",
        "@types/node": "^22.10.7",
        "@types/passport-google-oauth20": "^2.0.17",
        "@types/passport-jwt": "^4.0.1",
        "@types/pg": "^8.15.6",
        "@types/supertest": "^6.0.2",
        "@types/uuid": "^11.0.0",
        "eslint": "^9.18.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-plugin-prettier": "^5.2.2",
        "globals": "^16.0.0",
        "jest": "^30.0.0",
        "prettier": "^3.4.2",
        "prisma": "^7.2.0",
        "prisma-erd-generator": "^2.4.2",
        "source-map-support": "^0.5.21",
        "supertest": "^7.0.0",
        "ts-jest": "^29.2.5",
        "ts-loader": "^9.5.2",
        "ts-node": "^10.9.2",
